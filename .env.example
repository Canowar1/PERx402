# Shadow Proxy — environment variables
# Copy to .env and fill in values
# NEVER commit .env to git

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
ANCHOR_WALLET=~/.config/solana/id.json

# MagicBlock TEE
TEE_RPC_URL=https://tee.magicblock.app
PER_API_URL=https://per.magicblock.app

# x402
COINBASE_FACILITATOR_URL=https://x402.org/facilitator

# Token
USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Proxy server
PROXY_PORT=3001
DASHBOARD_URL=http://localhost:3000

# Wallet secrets — NEVER hardcode; generated by scripts/fund-devnet.ts
PROXY_WALLET_SECRET_KEY=<base58-encoded-proxy-wallet-secret-key>
AGENT_SECRET_KEY=<base58-encoded-agent-wallet-secret-key>

# Agent
PROXY_URL=http://localhost:3001
