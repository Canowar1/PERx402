{
  "name": "perx402-sdk",
  "version": "0.1.0",
  "description": "Private x402 payment SDK for AI agents on Solana — powered by MagicBlock's Private Ephemeral Rollup",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "x402",
    "solana",
    "privacy",
    "ai-agent",
    "shadow-proxy",
    "magicblock",
    "tee"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
